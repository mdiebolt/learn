<div class="text-sm text-white/80 space-y-2">
  <% case card.kind %>
  <% when Audiobook::Chapter::Card::MultipleChoice %>
    <p><strong>Answer:</strong> <%= card.kind.options[card.kind.correct_index] %></p>
    <% if card.kind.rationale.present? %><p class="text-white/60"><%= card.kind.rationale %></p><% end %>
  <% when Audiobook::Chapter::Card::Cloze %>
    <p><strong>Fills:</strong> <%= card.kind.answers.join(", ") %></p>
  <% when Audiobook::Chapter::Card::FreeResponse %>
    <p><strong>Reference:</strong> <%= card.kind.reference_answer %></p>
    <% if card.kind.rubric.present? %><p class="text-white/60"><%= card.kind.rubric %></p><% end %>
  <% when Audiobook::Chapter::Card::Ordering %>
    <ol class="list-decimal pl-5"><% card.kind.items.each do |i| %><li><%= i %></li><% end %></ol>
  <% when Audiobook::Chapter::Card::Matching %>
    <dl><% card.kind.pairs.each do |pair| %><div class="flex gap-2"><dt class="font-medium"><%= pair["left"] %></dt><dd>→ <%= pair["right"] %></dd></div><% end %></dl>
  <% end %>
</div>
