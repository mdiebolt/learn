<figure class="space-y-4">
  <figcaption class="flex items-center gap-3">
    <% if visual.caption.present? %>
      <span class="shrink-0 font-mono text-xs uppercase tracking-wider text-white/40">// <%= visual.caption %></span>
    <% end %>
    <hr class="grow border-t border-white/15">
    <span class="shrink-0 font-mono text-2xs uppercase tracking-wider text-white/40">reference</span>
    <span class="flex size-6 shrink-0 items-center justify-center border border-white/15 font-mono text-xs text-white/50" title="<%= visual.kind.model_name.element.titleize %>"><%= visual.kind.glyph %></span>
  </figcaption>
  <%= render visual.kind %>
</figure>
