<figure class="space-y-4">
  <% if visual.caption.present? %>
    <figcaption class="flex items-center gap-3">
      <span class="shrink-0 font-mono text-xs uppercase tracking-wider text-white/40">// <%= visual.caption %></span>
      <hr class="grow border-t border-white/15">
    </figcaption>
  <% end %>
  <%= render visual.kind %>
</figure>
