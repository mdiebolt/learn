<div class="px-8 py-12 max-w-3xl mx-auto space-y-6">
  <header class="space-y-1">
    <p class="text-2xs font-mono uppercase tracking-wide text-white/40"><%= link_to "[#{@audiobook.title}]", @audiobook, class: "ui-link" %> <span>.. Study Guide</span></p>
    <h1 class="text-2xl font-medium"><%= @chapter.title %></h1>
  </header>

  <%= turbo_stream_from @chapter, :study_guide %>
  <%= turbo_frame_tag dom_id(@chapter, :study_guide) do %>
    <% if @study_guide %>
      <ol class="space-y-20">
        <% @items.each do |item| %>
          <li><%= render item.itemable %></li>
        <% end %>
      </ol>
    <% else %>
      <div class="space-y-3">
        <p class="text-white/60">No study guide yet for this chapter.</p>
        <%= button_to "Generate study guide", audiobook_chapter_study_guide_path(@audiobook, @chapter), class: "ui-button" %>
      </div>
    <% end %>
  <% end %>
</div>
