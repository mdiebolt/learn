<%# locals: (audiobook:, chapter:, study_guide: nil, generating: false) %>
<%= turbo_frame_tag dom_id(chapter, :study_guide_control) do %>
  <% if study_guide %>
    <%= link_to "review study guide →", audiobook_chapter_study_guide_path(audiobook, chapter), data: { turbo_frame: "_top" }, class: "ui-link text-2xs font-mono uppercase tracking-wide text-amber-400" %>
  <% elsif generating %>
    <span class="text-2xs font-mono uppercase tracking-wide text-white/40">// generating study guide…</span>
  <% else %>
    <%= button_to "generate study guide", audiobook_chapter_study_guide_path(audiobook, chapter), class: "ui-link text-2xs font-mono uppercase tracking-wide text-white/50" %>
  <% end %>
<% end %>
