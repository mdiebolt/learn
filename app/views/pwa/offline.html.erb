<!DOCTYPE html>
<html lang="en">
<head>
  <title>You're offline</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    :root { color-scheme: only dark; }
    html, body { margin: 0; padding: 0; }
    body {
      font-family: "Geist", system-ui, -apple-system, sans-serif;
      -webkit-font-smoothing: antialiased;
      display: grid;
      place-items: center;
      min-height: 100dvh;
      background: #000;
      color: #fff;
      text-align: center;
      padding: 1.5rem;
    }
    .eyebrow {
      font-family: "Geist Mono", ui-monospace, SFMono-Regular, monospace;
      font-size: 0.6875rem;
      text-transform: uppercase;
      letter-spacing: 0.025em;
      color: rgba(255, 255, 255, 0.4);
      margin-bottom: 0.75rem;
    }
    h1 { font-size: 2.25rem; font-weight: 500; letter-spacing: -0.025em; margin: 0 0 0.75rem; }
    p { color: rgba(255, 255, 255, 0.6); margin: 0 0 2rem; max-width: 32ch; }
    button {
      font-family: "Geist Mono", ui-monospace, SFMono-Regular, monospace;
      font-size: 0.6875rem;
      text-transform: uppercase;
      letter-spacing: 0.025em;
      padding: 0.75rem 1.5rem;
      background: #fbbf24;
      color: #000;
      border: 0;
      cursor: pointer;
      transition: background 150ms;
    }
    button:hover { background: #fcd34d; }
  </style>
</head>
<body>
  <div>
    <div class="eyebrow">// offline</div>
    <h1>You're offline</h1>
    <p>Unable to connect. Check your internet connection and try again.</p>
    <form action="." method="get" aria-label="Retry loading this page">
      <button type="submit">retry</button>
    </form>
  </div>
</body>
</html>
