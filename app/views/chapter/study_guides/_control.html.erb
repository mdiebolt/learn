<% study_guide = local_assigns[:study_guide] %>
<% generating = local_assigns[:generating] || false %>
<%= turbo_frame_tag dom_id(chapter, :study_guide_control), class: "absolute right-full top-1/2 -translate-y-1/2 mr-3" do %>
  <% glyph = "flex size-6 items-center justify-center border border-white/15 font-mono text-xs text-white/50 transition" %>
  <% if study_guide %>
    <%= link_to "§", chapter_study_guide_path(chapter), data: { turbo_frame: "_top" }, title: "Review study guide", class: "#{glyph} hover:border-amber-400 hover:text-amber-400" %>
  <% elsif generating %>
    <span title="Generating study guide…" class="<%= glyph %> animate-pulse">§</span>
  <% else %>
    <%= button_to "§", chapter_study_guide_path(chapter), title: "Generate study guide", form_class: "contents", class: "#{glyph} opacity-40 hover:opacity-100 hover:border-amber-400 hover:text-amber-400" %>
  <% end %>
<% end %>
