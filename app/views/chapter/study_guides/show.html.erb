<div class="flex items-center justify-between gap-4">
  <%= link_to "[#{@audiobook.title}]", @audiobook, class: "ui-link" %>
</div>

<header class="mt-8 mb-12">
  <h1 class="ui-title truncate min-w-0"><%= @chapter.title %></h1>
</header>

<%= turbo_stream_from @chapter, :study_guide %>
<%= turbo_frame_tag dom_id(@chapter, :study_guide) do %>
  <% if @study_guide %>
    <ol class="space-y-20">
      <% @topics.each do |topic| %>
        <li id="<%= dom_id(topic.topical) %>"><%= render partial: topic.topical.to_partial_path, object: topic.topical %></li>
      <% end %>
    </ol>
  <% else %>
    <div class="space-y-3">
      <p class="text-white/60">No study guide yet for this chapter.</p>
      <%= button_to "Generate study guide", chapter_study_guide_path(@chapter), class: "ui-button" %>
    </div>
  <% end %>
<% end %>
