<div class="min-h-screen bg-gray-900 text-white">
  <header class="p-4 border-b border-gray-700">
    <%= link_to "← #{@audiobook.display_title}", @audiobook, class: "text-gray-400 hover:text-white text-sm" %>
    <h1 class="text-xl font-semibold mt-2"><%= @chapter.title %></h1>
  </header>

  <% if @words.any? %>
    <div class="p-8"
         data-controller="rsvp"
         data-rsvp-words-value="<%= @words.to_json %>"
         data-rsvp-start-ms-value="<%= @chapter.start_time_ms %>"
         data-rsvp-end-ms-value="<%= @chapter.end_time_ms %>"
         data-rsvp-next-chapter-url-value="<%= @next_chapter ? audiobook_chapter_path(@audiobook, @next_chapter) : "" %>"
         data-rsvp-autoplay-value="<%= @autoplay %>">

      <div class="rsvp-display bg-gray-800 rounded-lg h-48 flex items-center justify-center mb-8 relative font-mono text-5xl">
        <div class="rsvp-word">
          <span class="rsvp-before" data-rsvp-target="before"></span><span class="rsvp-focal text-red-500" data-rsvp-target="focal"></span><span class="rsvp-after" data-rsvp-target="after"></span>
        </div>
        <div class="absolute left-1/2 top-0 bottom-0 w-0.5 bg-red-500/30 -translate-x-1/2"></div>
      </div>

      <div class="flex items-center justify-end gap-2 mb-2">
        <label for="wpm" class="text-sm text-gray-400">Speed</label>
        <select id="wpm"
                data-action="change->rsvp#onWpmChange"
                class="bg-gray-800 text-white rounded px-2 py-1 text-sm">
          <% [150, 200, 250, 300, 400, 500, 600, 700, 800].each do |wpm| %>
            <option value="<%= wpm %>"><%= wpm %> WPM</option>
          <% end %>
        </select>
      </div>

      <div class="flex items-center gap-3 bg-gray-800 rounded-lg p-3">
        <button type="button"
                data-action="click->rsvp#togglePlay"
                data-rsvp-target="playButton"
                aria-label="Play"
                class="bg-gray-700 hover:bg-gray-600 rounded-full w-10 h-10 flex items-center justify-center text-lg shrink-0">
          ▶
        </button>
        <span data-rsvp-target="currentTime" class="text-sm text-gray-400 tabular-nums w-12">0:00</span>
        <input type="range"
               min="0"
               max="1000"
               value="0"
               step="1"
               data-rsvp-target="seek"
               data-action="input->rsvp#onSeek"
               aria-label="Seek"
               class="flex-1 accent-red-500">
        <span data-rsvp-target="duration" class="text-sm text-gray-400 tabular-nums w-12 text-right">0:00</span>
      </div>

      <audio data-rsvp-target="audio"
             data-action="play->rsvp#onPlay pause->rsvp#onPause seeked->rsvp#onSeeked loadedmetadata->rsvp#onLoadedMetadata"
             preload="metadata"
             class="hidden">
        <source src="<%= rails_blob_path(@audiobook.audio) %>" type="<%= @audiobook.audio.content_type %>">
      </audio>
    </div>
  <% else %>
    <div class="p-8 text-center">
      <p class="text-gray-400">
        Transcript not ready yet.
        <%= link_to "Back to audiobook", @audiobook, class: "text-blue-400 hover:underline" %>
      </p>
    </div>
  <% end %>
</div>
