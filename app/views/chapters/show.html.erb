<%# Wrapping the chapter in a Turbo Frame lets chapter-autoplay advance to %>
<%# the next chapter via `frame.src = ...` instead of `Turbo.visit`. A frame %>
<%# swap leaves <html> in place, so document-level fullscreen survives the %>
<%# transition; a body-replacing visit would drop fullscreen on most browsers. %>
<%= turbo_frame_tag "chapter", data: { turbo_action: "advance" } do %>
  <% if @words.any? %>
    <%= tag.div(**rsvp_container_attributes(audiobook: @audiobook, chapter: @chapter, words: @words, next_chapter: @next_chapter, autoplay: @autoplay, progress: @progress)) do %>
      <%# Top hover zone — back link, chapter title, and fullscreen fade in when cursor approaches the top edge. %>
      <div class="absolute top-0 left-0 right-0 h-24 group/header z-10">
        <div class="absolute top-0 left-0 right-0 px-6 pt-6 grid grid-cols-3 items-start gap-6 text-2xs font-mono uppercase tracking-wide tabular-nums transition-opacity duration-300 opacity-0 pointer-events-none group-hover/header:opacity-100 group-hover/header:pointer-events-auto">
          <%# `turbo_frame: "_top"` escapes the chapter frame so Turbo doesn't %>
          <%# look for a matching frame on the audiobook show page and surface %>
          <%# a "Content missing" error. %>
          <%= link_to @audiobook, data: { turbo_frame: "_top" }, class: "justify-self-start text-white/70 hover:text-amber-400 transition-colors" do %>
            [← back]
          <% end %>
          <div class="justify-self-center text-center min-w-0 truncate text-white/40"><%= @chapter.title %></div>
        </div>
      </div>

      <%# Full-viewport reading guide, pinned to the focal column. %>
      <div class="rsvp-line" aria-hidden="true"></div>

      <%# Word display: rendered as a single inline text run; the controller %>
      <%# translates it so the focal letter's center lands on the line X. %>
      <div class="rsvp-word text-[clamp(3.5rem,11vw,9rem)] font-medium leading-none">
        <span class="rsvp-word-text" data-rsvp-target="word"></span>
      </div>

      <%# Bottom hover zone — scrubber and time/wpm fade in when cursor approaches the bottom edge. %>
      <div class="absolute bottom-0 left-0 right-0 h-32 group/footer z-10">
        <footer class="absolute bottom-0 left-0 right-0 transition-opacity duration-300 opacity-0 pointer-events-none group-hover/footer:opacity-100 group-hover/footer:pointer-events-auto">
          <input type="range"
                 min="0" max="1000" value="0" step="1"
                 name="seek"
                 aria-label="Seek"
                 data-playback-target="seek"
                 data-action="input->playback#seek"
                 class="rsvp-scrubber">
          <div class="px-6 py-4 flex items-center justify-between text-2xs font-mono uppercase tracking-wide tabular-nums text-white/50">
            <div class="flex items-center gap-2">
              <span data-playback-target="currentTime">0:00</span>
              <span class="text-white/25">/</span>
              <span data-playback-target="duration">0:00</span>
            </div>

            <div class="flex items-center gap-5">
              <label class="flex items-center gap-2 cursor-pointer" data-playback-no-toggle>
                <span class="text-white/40">sync</span>
                <input type="range"
                       min="<%= User::AUDIO_OFFSET_MS_RANGE.begin %>"
                       max="<%= User::AUDIO_OFFSET_MS_RANGE.end %>"
                       step="25"
                       value="<%= Current.user.audio_offset_ms %>"
                       name="audio_offset_ms"
                       aria-label="Audio sync offset in milliseconds"
                       data-rsvp-target="audioOffset"
                       data-controller="autosave"
                       data-autosave-url-value="<%= preferences_path %>"
                       data-action="input->rsvp#setAudioOffset change->autosave#patch"
                       class="w-20 accent-amber-400 cursor-pointer">
                <span data-rsvp-target="audioOffsetReadout" class="text-white/40 w-12 text-right"><%= format("%+dms", Current.user.audio_offset_ms) %></span>
              </label>

              <button type="button"
                      aria-label="Toggle fullscreen"
                      data-action="fullscreen#toggle"
                      class="bg-transparent border-0 text-white/60 hover:text-amber-400 cursor-pointer">
                [fullscreen]
              </button>

              <select name="wpm"
                      aria-label="Reading speed"
                      data-playback-target="wpm"
                      data-controller="autosave"
                      data-autosave-url-value="<%= preferences_path %>"
                      data-action="change->playback#setRate change->autosave#patch"
                      class="bg-transparent border-0 text-white/60 hover:text-amber-400 cursor-pointer uppercase tracking-wide font-mono">
                <% User::WPM_OPTIONS.each do |wpm| %>
                  <option value="<%= wpm %>" class="bg-black text-white"<%= " selected" if wpm == Current.user.wpm %>><%= wpm %> wpm</option>
                <% end %>
              </select>
            </div>
          </div>
        </footer>
      </div>

      <%= tag.audio(**rsvp_audio_attributes) do %>
        <%= tag.source src: rails_blob_path(@audiobook.audio), type: @audiobook.audio.content_type %>
      <% end %>
    <% end %>
  <% else %>
    <div class="px-8 py-16 text-center space-y-4">
      <p class="font-mono text-2xs uppercase tracking-wide text-white/60">// transcript not ready yet</p>
      <%= link_to "[← back to audiobook]", @audiobook, class: "ui-link" %>
    </div>
  <% end %>
<% end %>
