<% wpm_options = [150, 200, 250, 300, 400, 500, 600, 700, 800] %>

<% if @words.any? %>
  <%= tag.div(
        class: "min-h-dvh grid place-items-center relative overflow-hidden group/page",
        data: {
          controller: "rsvp",
          rsvp_words_value: @words.to_json,
          rsvp_start_ms_value: @chapter.start_time_ms,
          rsvp_end_ms_value: @chapter.end_time_ms,
          rsvp_next_chapter_url_value: (@next_chapter ? audiobook_chapter_path(@audiobook, @next_chapter) : ""),
          rsvp_autoplay_value: @autoplay
        }) do %>
    <header class="absolute top-0 left-0 right-0 px-6 pt-6 flex items-start justify-between text-[0.6875rem] tabular-nums font-mono text-white/35 transition-opacity duration-500 group-hover/page:opacity-100 opacity-30 z-10">
      <%= link_to @audiobook, class: "hover:text-white transition-colors uppercase tracking-wide" do %>
        ← back
      <% end %>
      <div class="uppercase tracking-wide text-right max-w-[50ch] truncate"><%= @chapter.title %></div>
    </header>

    <div class="rsvp-word relative mx-auto text-[clamp(4.5rem,16vw,14rem)] font-medium tracking-tight leading-none">
      <span class="rsvp-before text-white" data-rsvp-target="before"></span><span class="rsvp-focal text-amber-400" data-rsvp-target="focal"></span><span class="rsvp-after text-white" data-rsvp-target="after"></span>
      <span aria-hidden="true" class="absolute left-1/2 -top-[0.35em] h-[0.25em] w-px bg-amber-400/70 -translate-x-1/2"></span>
      <span aria-hidden="true" class="absolute left-1/2 -bottom-[0.35em] h-[0.25em] w-px bg-amber-400/70 -translate-x-1/2"></span>
    </div>

    <footer class="absolute left-0 right-0 bottom-0 transition-opacity duration-500 group-hover/page:opacity-100 opacity-25 z-10">
      <input type="range"
             min="0" max="1000" value="0" step="1"
             name="seek"
             aria-label="Seek"
             data-rsvp-target="seek"
             data-action="input->rsvp#onSeek"
             class="block w-full appearance-none bg-transparent accent-amber-400 cursor-pointer">
      <div class="px-6 py-4 flex items-center justify-between text-[0.6875rem] font-mono tabular-nums text-white/60 uppercase tracking-wide">
        <div class="flex items-center gap-4">
          <button type="button"
                  data-action="click->rsvp#togglePlay"
                  data-rsvp-target="playButton"
                  aria-label="Play"
                  class="text-white hover:text-amber-400 transition-colors text-sm leading-none">
            ▶
          </button>
          <span data-rsvp-target="currentTime">0:00</span>
          <span class="text-white/30">/</span>
          <span data-rsvp-target="duration">0:00</span>
        </div>
        <select name="wpm"
                aria-label="Reading speed"
                data-action="change->rsvp#onWpmChange"
                class="bg-transparent border-0 text-white/60 hover:text-white focus:outline-none cursor-pointer uppercase tracking-wide font-mono">
          <% wpm_options.each do |wpm| %>
            <option value="<%= wpm %>" class="bg-black text-white"><%= wpm %> wpm</option>
          <% end %>
        </select>
      </div>
    </footer>

    <%= tag.audio(
          preload: "metadata",
          class: "hidden",
          data: {
            rsvp_target: "audio",
            action: "play->rsvp#onPlay pause->rsvp#onPause seeked->rsvp#onSeeked loadedmetadata->rsvp#onLoadedMetadata"
          }) do %>
      <%= tag.source src: rails_blob_path(@audiobook.audio), type: @audiobook.audio.content_type %>
    <% end %>
  <% end %>
<% else %>
  <div class="px-8 py-16 text-center">
    <p class="font-mono text-[0.6875rem] uppercase tracking-wide text-white/60">
      // transcript not ready yet ·
      <%= link_to "back to audiobook", @audiobook, class: "text-amber-400 hover:underline" %>
    </p>
  </div>
<% end %>
