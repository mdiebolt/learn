<% if @words.any? %>
  <%= tag.div(
        class: "min-h-dvh grid place-items-center relative overflow-hidden select-none cursor-default",
        data: {
          controller: "rsvp",
          action: "click->rsvp#togglePlay keydown@window->rsvp#onKeydown",
          rsvp_words_value: @words.to_json,
          rsvp_start_ms_value: @chapter.start_time_ms,
          rsvp_end_ms_value: @chapter.end_time_ms,
          rsvp_next_chapter_url_value: (@next_chapter ? audiobook_chapter_path(@audiobook, @next_chapter) : ""),
          rsvp_autoplay_value: @autoplay,
          rsvp_preferences_url_value: preferences_path,
          rsvp_progress_url_value: audiobook_chapter_progress_path(@audiobook, @chapter),
          rsvp_initial_progress_ms_value: (@progress && !@progress.completed? ? @progress.progress_ms : 0)
        }) do %>

    <%# Top hover zone — back link + chapter title fade in when cursor approaches the top edge. %>
    <div class="absolute top-0 left-0 right-0 h-24 group/header z-10">
      <div class="absolute top-0 left-0 right-0 px-6 pt-6 flex items-start justify-between gap-6 text-[0.6875rem] font-mono uppercase tracking-wide tabular-nums transition-opacity duration-300 opacity-0 pointer-events-none group-hover/header:opacity-100 group-hover/header:pointer-events-auto">
        <%= link_to @audiobook, class: "text-white/70 hover:text-amber-400 transition-colors" do %>
          [← back]
        <% end %>
        <div class="text-right max-w-[50ch] truncate text-white/40"><%= @chapter.title %></div>
      </div>
    </div>

    <%# Full-viewport reading guide, pinned to the focal column. %>
    <div class="rsvp-line" aria-hidden="true"></div>

    <%# Word display: rendered as a single inline text run; the controller %>
    <%# translates it so the focal letter's center lands on the line X. %>
    <div class="rsvp-word text-[clamp(3.5rem,11vw,9rem)] font-medium leading-none">
      <span class="rsvp-word-text" data-rsvp-target="word"></span>
    </div>

    <%# Bottom hover zone — scrubber and time/wpm fade in when cursor approaches the bottom edge. %>
    <div class="absolute bottom-0 left-0 right-0 h-32 group/footer z-10">
      <footer class="absolute bottom-0 left-0 right-0 transition-opacity duration-300 opacity-0 pointer-events-none group-hover/footer:opacity-100 group-hover/footer:pointer-events-auto">
        <input type="range"
               min="0" max="1000" value="0" step="1"
               name="seek"
               aria-label="Seek"
               data-rsvp-target="seek"
               data-action="input->rsvp#onSeek"
               class="rsvp-scrubber">
        <div class="px-6 py-4 flex items-center justify-between text-[0.6875rem] font-mono uppercase tracking-wide tabular-nums text-white/50">
          <div class="flex items-center gap-2">
            <span data-rsvp-target="currentTime">0:00</span>
            <span class="text-white/25">/</span>
            <span data-rsvp-target="duration">0:00</span>
          </div>
          <div class="flex items-center gap-4">
            <button type="button"
                    aria-label="Toggle fullscreen"
                    data-action="rsvp#toggleFullscreen"
                    class="bg-transparent border-0 text-white/60 hover:text-amber-400 focus:outline-none cursor-pointer uppercase tracking-wide font-mono">
              [fullscreen]
            </button>
            <select name="wpm"
                    aria-label="Reading speed"
                    data-rsvp-target="wpm"
                    data-action="change->rsvp#onWpmChange"
                    class="bg-transparent border-0 text-white/60 hover:text-amber-400 focus:outline-none cursor-pointer uppercase tracking-wide font-mono">
              <% User::WPM_OPTIONS.each do |wpm| %>
                <option value="<%= wpm %>" class="bg-black text-white"<%= " selected" if wpm == Current.user.wpm %>><%= wpm %> wpm</option>
              <% end %>
            </select>
          </div>
        </div>
      </footer>
    </div>

    <%= tag.audio(
          preload: "metadata",
          class: "hidden",
          data: {
            rsvp_target: "audio",
            action: "play->rsvp#onPlay pause->rsvp#onPause seeked->rsvp#onSeeked loadedmetadata->rsvp#onLoadedMetadata"
          }) do %>
      <%= tag.source src: rails_blob_path(@audiobook.audio), type: @audiobook.audio.content_type %>
    <% end %>
  <% end %>
<% else %>
  <div class="px-8 py-16 text-center space-y-4">
    <p class="font-mono text-[0.6875rem] uppercase tracking-wide text-white/60">// transcript not ready yet</p>
    <%= link_to "[← back to audiobook]", @audiobook, class: "font-mono text-[0.6875rem] uppercase tracking-wide text-white/70 hover:text-amber-400 transition-colors" %>
  </div>
<% end %>
