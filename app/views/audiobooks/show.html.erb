<div class="max-w-4xl mx-auto py-8 px-4">
  <%= link_to "← Back to Audiobooks", audiobooks_path, class: "text-gray-600 hover:text-gray-900 mb-4 inline-block" %>

  <header class="mb-8">
    <h1 class="text-3xl font-bold"><%= @audiobook.display_title %></h1>
    <% if @audiobook.author.present? %>
      <p class="text-xl text-gray-600"><%= @audiobook.author %></p>
    <% end %>
  </header>

  <% case @audiobook.status.to_sym %>
  <% when :pending, :processing %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-8 text-center">
      <p class="text-yellow-800">Detecting chapters... reload in a moment.</p>
    </div>
  <% when :failed %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-8 text-center">
      <p class="text-red-800">Chapter detection failed. Try uploading again.</p>
    </div>
  <% when :ready %>
    <section class="mb-8">
      <h2 class="text-xl font-semibold mb-3">Chapters</h2>
      <div class="space-y-2">
        <% @audiobook.chapters.each do |chapter| %>
          <div class="bg-white rounded-lg shadow p-4 flex justify-between items-center">
            <div>
              <h3 class="font-medium">
                <% if @audiobook.transcript&.ready? %>
                  <%= link_to chapter.title,
                        audiobook_chapter_path(@audiobook, chapter),
                        class: "hover:text-blue-600" %>
                <% else %>
                  <%= chapter.title %>
                <% end %>
              </h3>
              <p class="text-sm text-gray-500">
                <%= "%d:%02d" % chapter.duration_ms.divmod(60_000).then { |m, ms| [m, ms / 1000] } %>
              </p>
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold mb-3">Transcript</h2>
      <%= render "transcript_panel", audiobook: @audiobook %>
    </section>
  <% end %>

  <div class="mt-8">
    <%= button_to "Delete", @audiobook, method: :delete,
          form: { data: { turbo_confirm: "Delete this audiobook?" } },
          class: "text-red-600 hover:text-red-800" %>
  </div>
</div>
