<div class="max-w-3xl mx-auto px-6 py-12 sm:py-16">
  <%= link_to audiobooks_path, class: "font-mono text-[0.6875rem] uppercase tracking-wide text-white/70 hover:text-amber-400 transition-colors" do %>
    [← back to library]
  <% end %>

  <header class="mt-8 mb-12">
    <div class="font-mono text-[0.6875rem] uppercase tracking-wide text-white/40 mb-3">// audiobook</div>
    <h1 class="text-4xl sm:text-5xl font-medium tracking-tight"><%= @audiobook.display_title %></h1>
    <% if @audiobook.author.present? %>
      <p class="mt-3 text-lg text-white/60"><%= @audiobook.author %></p>
    <% end %>
  </header>

  <% case @audiobook.status.to_sym %>
  <% when :pending, :processing %>
    <div class="border border-amber-400/30 px-6 py-8 text-center">
      <p class="font-mono text-[0.6875rem] uppercase tracking-wide text-amber-400">// detecting chapters · reload in a moment</p>
    </div>
  <% when :failed %>
    <div class="border border-red-400/30 px-6 py-8 text-center">
      <p class="font-mono text-[0.6875rem] uppercase tracking-wide text-red-400">// chapter detection failed · try uploading again</p>
    </div>
  <% when :ready %>
    <section class="mb-16">
      <h2 class="font-mono text-[0.6875rem] uppercase tracking-wide text-white/40 mb-4">// chapters</h2>
      <ul role="list" class="border-t border-white/10">
        <% @audiobook.chapters.each_with_index do |chapter, i| %>
          <li class="border-b border-white/10">
            <% if @audiobook.transcript&.ready? %>
              <%= link_to audiobook_chapter_path(@audiobook, chapter), class: "flex items-baseline justify-between gap-4 py-4 -mx-4 px-4 hover:bg-white/[0.02] transition-colors group" do %>
                <div class="flex items-baseline gap-4 min-w-0">
                  <span class="font-mono text-[0.6875rem] tabular-nums text-white/40 shrink-0"><%= "%02d" % (i + 1) %></span>
                  <span class="font-medium truncate group-hover:text-amber-400 transition-colors"><%= chapter.title %></span>
                </div>
                <span class="font-mono text-[0.6875rem] tabular-nums text-white/40 shrink-0"><%= "%d:%02d" % chapter.duration_ms.divmod(60_000).then { |m, ms| [m, ms / 1000] } %></span>
              <% end %>
            <% else %>
              <div class="flex items-baseline justify-between gap-4 py-4">
                <div class="flex items-baseline gap-4 min-w-0">
                  <span class="font-mono text-[0.6875rem] tabular-nums text-white/40 shrink-0"><%= "%02d" % (i + 1) %></span>
                  <span class="text-white/60 truncate"><%= chapter.title %></span>
                </div>
                <span class="font-mono text-[0.6875rem] tabular-nums text-white/40 shrink-0"><%= "%d:%02d" % chapter.duration_ms.divmod(60_000).then { |m, ms| [m, ms / 1000] } %></span>
              </div>
            <% end %>
          </li>
        <% end %>
      </ul>
    </section>

    <section class="mb-16">
      <h2 class="font-mono text-[0.6875rem] uppercase tracking-wide text-white/40 mb-4">// transcript</h2>
      <%= turbo_stream_from @audiobook, :transcript_panel %>
      <%= render "transcript_panel", audiobook: @audiobook %>
    </section>
  <% end %>

  <div class="mt-16 pt-6 border-t border-white/10">
    <%= button_to "[delete audiobook]", @audiobook, method: :delete,
          form: { data: { turbo_confirm: "Delete this audiobook?" } },
          class: "font-mono text-[0.6875rem] uppercase tracking-wide text-white/40 hover:text-red-400 transition-colors cursor-pointer" %>
  </div>
</div>
