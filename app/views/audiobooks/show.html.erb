<div class="font-mono <%= container_classes %>">
  <div class="flex items-center justify-between gap-4">
    <%= link_to audiobooks_path, class: "ui-link" do %>
      [← back to library]
    <% end %>
    <%= delete_audiobook_button(@audiobook) %>
  </div>

  <header class="mt-8 mb-12">
    <div class="ui-eyebrow mb-3">// audiobook</div>
    <div class="flex items-center justify-between gap-6">
      <h1 class="ui-title truncate min-w-0"><%= @audiobook.title %></h1>
      <div class="shrink-0">
        <%= turbo_stream_from @audiobook, :transcript_badge %>
        <%= transcript_badge(@audiobook) %>
      </div>
    </div>
    <% if @audiobook.author.present? %>
      <p class="mt-3 text-lg text-white/60"><%= @audiobook.author %></p>
    <% end %>
  </header>

  <% case @audiobook.status.to_sym %>
  <% when :pending, :processing %>
    <div class="border border-amber-400/30 px-6 py-8 text-center">
      <p class="text-2xs uppercase tracking-wide text-amber-400">// detecting chapters · reload in a moment</p>
    </div>
  <% when :failed %>
    <div class="border border-red-400/30 px-6 py-8 text-center">
      <p class="text-2xs uppercase tracking-wide text-red-400">// chapter detection failed · try uploading again</p>
    </div>
  <% when :ready %>
    <section>
      <h2 class="ui-eyebrow mb-3">// chapters</h2>
      <ul role="list">
        <% @audiobook.chapters.each_with_index do |chapter, i| %>
          <% progress = @progresses_by_chapter_id[chapter.id] %>
          <% duration_str = "%02d:%02d" % chapter.duration_ms.divmod(60_000).then { |m, ms| [m, ms / 1000] } %>
          <li class="relative">
            <% if chapter.transcription_ready? %>
              <% fraction = progress&.fraction_through(chapter) || 0 %>
              <div class="hidden"><%= turbo_stream_from chapter, :study_guide_control %></div>
              <%= render "chapter/study_guides/control", chapter:, study_guide: @study_guides_by_chapter_id[chapter.id] %>
              <%= link_to chapter_path(chapter), class: "block py-3 -mx-4 px-4 hover:bg-white/[0.02] transition-colors group" do %>
                <div class="flex items-baseline justify-between gap-4">
                  <div class="flex items-baseline gap-4 min-w-0">
                    <span class="text-2xs tabular-nums text-white/40 shrink-0"><%= "%02d" % (i + 1) %></span>
                    <span class="font-medium truncate <%= progress&.completed? ? "text-white/50" : "" %> group-hover:text-amber-400 transition-colors"><%= chapter.title %></span>
                  </div>
                  <span class="shrink-0 text-2xs uppercase tracking-wide tabular-nums text-white/40"><%= duration_str %></span>
                </div>
                <div class="overflow-hidden whitespace-nowrap progress-leader text-xs" style="--p: <%= (fraction * 100).round %>%" aria-hidden="true"><%= "." * 240 %></div>
              <% end %>
            <% else %>
              <div class="py-3">
                <div class="flex items-baseline justify-between gap-4">
                  <div class="flex items-baseline gap-4 min-w-0">
                    <span class="text-2xs tabular-nums text-white/40 shrink-0"><%= "%02d" % (i + 1) %></span>
                    <span class="text-white/60 truncate"><%= chapter.title %></span>
                  </div>
                  <span class="shrink-0 text-2xs uppercase tracking-wide tabular-nums text-white/40"><%= duration_str %></span>
                </div>
                <div class="overflow-hidden whitespace-nowrap progress-leader text-xs" style="--p: 0%" aria-hidden="true"><%= "." * 240 %></div>
              </div>
            <% end %>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>
</div>
