<div class="max-w-3xl mx-auto px-6 py-12 sm:py-16">
  <header class="flex items-end justify-between gap-6 mb-12">
    <div>
      <div class="font-mono text-[0.6875rem] uppercase tracking-wide text-white/40 mb-3">// library</div>
      <h1 class="text-4xl sm:text-5xl font-medium tracking-tight">Your audiobooks</h1>
    </div>
    <%= link_to "[+ new]", new_audiobook_path, class: "font-mono text-[0.6875rem] uppercase tracking-wide text-white/70 hover:text-amber-400 transition-colors shrink-0" %>
  </header>

  <% if @audiobooks.any? %>
    <ul role="list">
      <% @audiobooks.each do |audiobook| %>
        <%= render "audiobook", audiobook: audiobook %>
      <% end %>
    </ul>
  <% else %>
    <div class="border border-white/10 px-6 py-16 text-center">
      <p class="text-white/60 mb-5">No audiobooks yet.</p>
      <%= link_to "[+ add your first audiobook]", new_audiobook_path, class: "font-mono text-[0.6875rem] uppercase tracking-wide text-white/70 hover:text-amber-400 transition-colors" %>
    </div>
  <% end %>
</div>
