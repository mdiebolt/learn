<header class="mt-14 flex items-end justify-between gap-6 mb-12">
  <h1 class="ui-title">Audiobooks</h1>
  <%= link_to "[new]", new_audiobook_path, class: "ui-link shrink-0" %>
</header>

<% if @audiobooks.any? %>
  <ul role="list">
    <%= render @audiobooks %>
  </ul>
<% else %>
  <div class="border border-white/10 px-6 py-16 text-center">
    <p class="text-white/60 mb-5">No audiobooks yet.</p>
    <%= link_to "[+ add your first audiobook]", new_audiobook_path, class: "ui-link" %>
  </div>
<% end %>
