<div class="flex items-center justify-between gap-4 h-6">
  <div></div>
  <div></div>
</div>

<header class="mt-8 mb-12">
  <div class="flex items-baseline justify-between gap-6">
    <h1 class="ui-title truncate min-w-0">Audiobooks</h1>
    <div class="shrink-0">
      <%= link_to "[new]", new_audiobook_path, class: "ui-link" %>
    </div>
  </div>
</header>

<% if @audiobooks.any? %>
  <ul role="list">
    <%= render @audiobooks %>
  </ul>
<% else %>
  <div class="border border-white/10 px-6 py-16 text-center">
    <p class="text-white/60 mb-5">No audiobooks yet.</p>
    <%= link_to "[+ add your first audiobook]", new_audiobook_path, class: "ui-link" %>
  </div>
<% end %>
