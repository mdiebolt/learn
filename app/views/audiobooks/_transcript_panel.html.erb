<% transcript = audiobook.transcript %>
<% case transcript&.status&.to_sym %>
<% when nil, :pending %>
  <div class="bg-white rounded-lg shadow p-4">
    <p class="text-sm text-gray-600 mb-3">
      Run ElevenLabs Scribe to transcribe this audiobook with word-level timestamps.
      List pricing is about $0.40/hour of audio.
    </p>
    <%= button_to "Transcribe with Scribe",
          transcribe_audiobook_path(audiobook),
          method: :post,
          form: { data: { turbo_confirm: "This will call ElevenLabs and incur cost. Continue?" } },
          class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
  </div>
<% when :transcribing %>
  <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
    <p class="text-yellow-800">Transcribing... reload in a few minutes.</p>
  </div>
<% when :failed %>
  <div class="bg-red-50 border border-red-200 rounded-lg p-4">
    <p class="text-red-800 mb-3">Transcription failed.</p>
    <%= button_to "Retry",
          transcribe_audiobook_path(audiobook),
          method: :post,
          class: "bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700" %>
  </div>
<% when :ready %>
  <div class="bg-green-50 border border-green-200 rounded-lg p-4">
    <p class="text-green-800">
      Transcribed (<%= pluralize(transcript.words.count, "word") %>).
    </p>
  </div>
<% end %>
