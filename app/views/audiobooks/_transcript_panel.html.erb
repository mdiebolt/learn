<% transcript = audiobook.transcript %>
<div id="<%= dom_id(audiobook, :transcript_panel) %>">
  <% case transcript&.status&.to_sym %>
  <% when nil, :pending %>
    <div class="bg-white rounded-lg shadow p-4">
      <p class="text-sm text-gray-600 mb-3">
        Run ElevenLabs Scribe to transcribe this audiobook with word-level timestamps.
        List pricing is about $0.40/hour of audio.
      </p>
      <%= button_to "Transcribe with Scribe",
            transcribe_audiobook_path(audiobook),
            method: :post,
            form: { data: { turbo_confirm: "This will call ElevenLabs and incur cost. Continue?" } },
            class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
    </div>
  <% when :transcribing %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 flex items-center gap-3">
      <svg class="animate-spin h-5 w-5 text-yellow-700 shrink-0" viewBox="0 0 24 24" fill="none">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
      </svg>
      <p class="text-yellow-800">
        <%= transcript.progress_message.presence || "Transcribing…" %>
      </p>
    </div>
  <% when :failed %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <p class="text-red-800 mb-3">Transcription failed.</p>
      <%= button_to "Retry",
            transcribe_audiobook_path(audiobook),
            method: :post,
            class: "bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700" %>
    </div>
  <% when :ready %>
    <div class="bg-green-50 border border-green-200 rounded-lg p-4">
      <p class="text-green-800">
        Transcribed (<%= pluralize(transcript.words.count, "word") %>).
      </p>
    </div>
  <% end %>
</div>
