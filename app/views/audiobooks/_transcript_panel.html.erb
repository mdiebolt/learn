<% transcript = audiobook.transcript %>
<div id="<%= dom_id(audiobook, :transcript_panel) %>">
  <% case transcript&.status&.to_sym %>
  <% when nil, :pending %>
    <div class="border border-white/10 p-5 space-y-4">
      <p class="text-sm text-white/60">
        Run ElevenLabs Scribe to transcribe this audiobook with word-level timestamps.
        List pricing is about $0.40/hour of audio.
      </p>
      <%= button_to "transcribe with scribe",
            audiobook_transcription_path(audiobook),
            method: :post,
            form: { data: { turbo_confirm: "This will call ElevenLabs and incur cost. Continue?" } },
            class: "font-mono text-[0.6875rem] uppercase tracking-wide text-white hover:text-amber-400 hover:border-amber-400 border border-white/20 px-4 py-2.5 transition-colors cursor-pointer" %>
    </div>
  <% when :transcribing %>
    <div class="border border-amber-400/30 p-5 flex items-center gap-4">
      <svg class="animate-spin size-4 text-amber-400 shrink-0" viewBox="0 0 24 24" fill="none">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
      </svg>
      <p class="font-mono text-[0.6875rem] uppercase tracking-wide text-amber-400">
        // <%= transcript.progress_message.presence || "transcribing…" %>
      </p>
    </div>
  <% when :failed %>
    <div class="border border-red-400/30 p-5 space-y-4">
      <p class="font-mono text-[0.6875rem] uppercase tracking-wide text-red-400">// transcription failed</p>
      <%= button_to "retry",
            audiobook_transcription_path(audiobook),
            method: :post,
            class: "font-mono text-[0.6875rem] uppercase tracking-wide text-white hover:text-red-400 hover:border-red-400 border border-white/20 px-4 py-2.5 transition-colors cursor-pointer" %>
    </div>
  <% when :ready %>
    <div class="border border-white/10 p-5">
      <p class="font-mono text-[0.6875rem] uppercase tracking-wide text-amber-400">
        // ready · <%= pluralize(transcript.words.count, "word") %>
      </p>
    </div>
  <% end %>
</div>
