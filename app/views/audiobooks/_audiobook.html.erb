<li class="border-b border-white/10">
  <%= link_to audiobook, class: "flex items-center justify-between gap-6 py-5 -mx-4 px-4 hover:bg-white/[0.02] transition-colors group" do %>
    <div class="min-w-0">
      <h2 class="text-lg font-medium tracking-tight truncate group-hover:text-amber-400 transition-colors">
        <%= audiobook.display_title %>
      </h2>
      <% if audiobook.author.present? %>
        <p class="text-sm text-white/50 mt-1 truncate"><%= audiobook.author %></p>
      <% end %>
    </div>
    <div class="font-mono text-[0.6875rem] uppercase tracking-wide shrink-0 tabular-nums">
      <% case audiobook.status.to_sym %>
      <% when :ready %>
        <span class="text-amber-400">// ready</span>
      <% when :processing %>
        <span class="text-white/60">// processing</span>
      <% when :failed %>
        <span class="text-red-400">// failed</span>
      <% else %>
        <span class="text-white/40">// pending</span>
      <% end %>
    </div>
  <% end %>
</li>
