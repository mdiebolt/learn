<div class="bg-white rounded-lg shadow p-6">
  <div class="flex justify-between items-start">
    <div>
      <h2 class="text-xl font-semibold">
        <%= link_to audiobook.display_title, audiobook, class: "hover:text-blue-600" %>
      </h2>
      <% if audiobook.author.present? %>
        <p class="text-gray-600"><%= audiobook.author %></p>
      <% end %>
      <p class="text-sm text-gray-400 mt-2">Status: <%= audiobook.status.humanize %></p>
    </div>

    <% case audiobook.status.to_sym
       when :ready %>
      <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded">Ready</span>
    <% when :processing %>
      <span class="bg-yellow-100 text-yellow-800 text-xs px-2 py-1 rounded">Processing</span>
    <% when :failed %>
      <span class="bg-red-100 text-red-800 text-xs px-2 py-1 rounded">Failed</span>
    <% else %>
      <span class="bg-gray-100 text-gray-800 text-xs px-2 py-1 rounded">Pending</span>
    <% end %>
  </div>
</div>
