<% content_for :breadcrumb do %>
  <%= link_to "[audiobooks]", audiobooks_path, class: "ui-link" %>
<% end %>
<% content_for :title, "New audiobook" %>

<%= form_with model: @audiobook, class: "space-y-8" do |f| %>
  <%= error_summary @audiobook %>

  <div>
    <%= f.label :audio, "// audio file (m4b or mp3)", class: "mb-3" %>
    <%= f.file_field :audio, accept: ".m4b,.mp3", direct_upload: true %>
    <p class="text-xs text-white/40 mt-3">
      Audiobook files can be large. The upload will go directly from your browser to storage.
    </p>
  </div>

  <%= f.submit "upload" %>
<% end %>
