<div class="max-w-3xl mx-auto px-6 py-12 sm:py-16">
  <%= link_to audiobooks_path, class: "ui-link" do %>
    [← back to library]
  <% end %>

  <header class="mt-8 mb-12">
    <div class="ui-eyebrow mb-3">// upload</div>
    <h1 class="ui-title">New audiobook</h1>
  </header>

  <%= form_with model: @audiobook, class: "space-y-8" do |f| %>
    <% if @audiobook.errors.any? %>
      <div class="ui-flash ui-flash--alert space-y-1">
        <% @audiobook.errors.full_messages.each do |message| %>
          <div>// <%= message %></div>
        <% end %>
      </div>
    <% end %>

    <div>
      <%= f.label :audio, "// audio file (m4b or mp3)", class: "ui-label mb-3" %>
      <%= f.file_field :audio,
            accept: ".m4b,.mp3",
            direct_upload: true,
            class: "ui-input ui-input--file" %>
      <p class="text-xs text-white/40 mt-3">
        Audiobook files can be large. The upload will go directly from your browser to storage.
      </p>
    </div>

    <%= f.submit "upload", class: "ui-button ui-button--accent" %>
  <% end %>
</div>
