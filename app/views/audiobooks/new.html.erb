<div class="max-w-xl mx-auto py-8 px-4">
  <h1 class="text-3xl font-bold mb-8">New Audiobook</h1>

  <%= form_with model: @audiobook, class: "space-y-6" do |f| %>
    <% if @audiobook.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <ul class="text-red-800 text-sm">
          <% @audiobook.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :audio, "Audio file (M4B or MP3)", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.file_field :audio,
            accept: ".m4b,.mp3",
            direct_upload: true,
            class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" %>
      <p class="text-xs text-gray-500 mt-2">
        Audiobook files can be large. The upload will go directly from your browser to storage.
      </p>
    </div>

    <div>
      <%= f.submit "Upload", class: "w-full bg-blue-600 text-white py-3 px-4 rounded-lg hover:bg-blue-700 cursor-pointer" %>
    </div>
  <% end %>
</div>
