<!DOCTYPE html>
<html lang="en" class="scheme-only-dark">
  <%= render "layouts/head" %>

  <body class="min-h-dvh bg-black text-white antialiased">
    <main class="isolate">
      <button type="button" popovertarget="app-menu" class="app-logo absolute top-4 left-1/2 -translate-x-1/2 size-10 cursor-pointer">
        <%= image_tag "logo.jpeg", alt: "Learn Logo" %>
      </button>

      <div id="app-menu" popover class="app-menu">
        <%= link_to "[audiobooks]", audiobooks_path, class: "ui-link" %>
        <%= link_to "[remember]", remember_path, class: "ui-link" %>
      </div>

      <div class="max-w-3xl mx-auto px-6 py-12 sm:py-16">
        <div class="h-6">
          <%= yield :breadcrumb %>
        </div>

        <header class="mt-8 mb-12">
          <div class="flex items-baseline justify-between gap-6">
            <h1 class="ui-title truncate min-w-0">
              <%= yield :title %>
            </h1>

            <div class="shrink-0">
              <%= yield :cta %>
            </div>
          </div>

          <%= yield :subtitle %>
        </header>

        <%= yield %>
      </div>
    </main>
  </body>
</html>
