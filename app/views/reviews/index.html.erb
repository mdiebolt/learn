<div class="px-8 py-12 max-w-3xl mx-auto space-y-6">
  <header class="space-y-1">
    <h1 class="text-2xl font-medium">Due today</h1>
    <p class="text-xs font-mono uppercase tracking-wide text-white/40"><%= pluralize(@due_cards.size, "card") %></p>
  </header>

  <% if @due_cards.any? %>
    <ol class="space-y-6"><% @due_cards.each do |card| %><li class="border border-white/10 rounded p-5"><%= render card %></li><% end %></ol>
  <% else %>
    <p class="text-white/60">Nothing due. Come back later.</p>
  <% end %>
</div>
