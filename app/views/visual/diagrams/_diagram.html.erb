<div class="text-sm text-white/80 space-y-2">
  <div>
    <h4 class="text-xs font-mono uppercase tracking-wide text-white/40">Nodes</h4>
    <ul class="pl-4 list-disc">
      <% diagram.nodes.each do |n| %>
        <li>
          <%= n["label"].presence || n["id"] %>
        </li>
      <% end %>
    </ul>
  </div>
  <div>
    <h4 class="text-xs font-mono uppercase tracking-wide text-white/40">Edges</h4>
    <ul class="pl-4 list-disc">
      <% diagram.edges.each do |e| %>
        <li>
          <%= e["from"] %> → <%= e["to"] %>
          <%= " (#{e["label"]})" if e["label"].present? %>
        </li>
      <% end %>
    </ul>
  </div>
</div>
