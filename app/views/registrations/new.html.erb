<% content_for :title, "Sign up" %>

<%= form_with model: @user, url: registrations_path, class: "space-y-8" do |form| %>
  <%= error_summary @user %>

  <div>
    <%= form.label :email_address, "// email", class: "mb-2" %>
    <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username" %>
  </div>
  <div>
    <%= form.label :password, "// password", class: "mb-2" %>
    <%= form.password_field :password, required: true, autocomplete: "new-password", maxlength: 72 %>
  </div>
  <div>
    <%= form.label :password_confirmation, "// confirm password", class: "mb-2" %>
    <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72 %>
  </div>

  <div class="flex items-center justify-between gap-4 pt-4">
    <%= form.submit "sign up" %>
    <%= link_to "[sign in instead]", new_session_path, class: "ui-link" %>
  </div>
<% end %>
