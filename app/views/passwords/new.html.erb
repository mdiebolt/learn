<div class="max-w-sm mx-auto px-6 py-16 sm:py-24">
  <% if alert = flash[:alert] %>
    <p id="alert" class="ui-flash ui-flash--alert mb-8">// <%= alert %></p>
  <% end %>

  <h1 class="ui-title mb-12">Reset Password</h1>

  <%= form_with url: passwords_path, class: "space-y-8" do |form| %>
    <div>
      <%= form.label :email_address, "// email", class: "ui-label mb-2" %>
      <%= form.email_field :email_address,
            required: true, autofocus: true, autocomplete: "username",
            value: params[:email_address],
            class: "ui-input ui-input--email" %>
    </div>

    <div class="flex items-center justify-between gap-4 pt-4">
      <%= form.submit "email instructions", class: "ui-button ui-button--accent" %>
      <%= link_to "[← back to sign in]", new_session_path, class: "ui-link" %>
    </div>
  <% end %>
</div>
