<div class="max-w-sm mx-auto px-6 py-16 sm:py-24">
  <% if alert = flash[:alert] %>
    <p id="alert" class="border border-red-400/30 px-4 py-3 mb-8 font-mono text-[0.6875rem] uppercase tracking-wide text-red-400">// <%= alert %></p>
  <% end %>

  <div class="font-mono text-[0.6875rem] uppercase tracking-wide text-white/40 mb-3">// reset</div>
  <h1 class="text-4xl font-medium tracking-tight mb-12">Update your password</h1>

  <%= form_with url: password_path(params[:token]), method: :put, class: "space-y-8" do |form| %>
    <div>
      <%= form.label :password, "// new password", class: "block font-mono text-[0.6875rem] uppercase tracking-wide text-white/40 mb-2" %>
      <%= form.password_field :password,
            required: true, autocomplete: "new-password", maxlength: 72,
            class: "block w-full bg-transparent border-0 border-b border-white/20 focus:border-amber-400 focus:outline-none px-0 py-3 text-base placeholder:text-white/30" %>
    </div>
    <div>
      <%= form.label :password_confirmation, "// confirm new password", class: "block font-mono text-[0.6875rem] uppercase tracking-wide text-white/40 mb-2" %>
      <%= form.password_field :password_confirmation,
            required: true, autocomplete: "new-password", maxlength: 72,
            class: "block w-full bg-transparent border-0 border-b border-white/20 focus:border-amber-400 focus:outline-none px-0 py-3 text-base placeholder:text-white/30" %>
    </div>

    <div class="pt-4">
      <%= form.submit "save",
            class: "font-mono text-[0.6875rem] uppercase tracking-wide text-black bg-amber-400 hover:bg-amber-300 px-6 py-3 cursor-pointer transition-colors" %>
    </div>
  <% end %>
</div>
