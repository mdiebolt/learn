<div class="max-w-sm mx-auto px-6 py-16 sm:py-24">
  <% if alert = flash[:alert] %>
    <p id="alert" class="ui-flash ui-flash--alert mb-8">// <%= alert %></p>
  <% end %>

  <h1 class="ui-title mb-12">Update your password</h1>

  <%= form_with url: password_path(params[:token]), method: :put, class: "space-y-8" do |form| %>
    <div>
      <%= form.label :password, "// new password", class: "ui-label mb-2" %>
      <%= form.password_field :password,
            required: true, autocomplete: "new-password", maxlength: 72,
            class: "ui-input ui-input--password" %>
    </div>
    <div>
      <%= form.label :password_confirmation, "// confirm new password", class: "ui-label mb-2" %>
      <%= form.password_field :password_confirmation,
            required: true, autocomplete: "new-password", maxlength: 72,
            class: "ui-input ui-input--password" %>
    </div>

    <div class="pt-4">
      <%= form.submit "save", class: "ui-button ui-button--accent" %>
    </div>
  <% end %>
</div>
