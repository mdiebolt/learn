<%= auth_panel "Update your password" do %>
  <%= form_with url: password_path(params[:token]), method: :put, class: "space-y-8" do |form| %>
    <div>
      <%= form.label :password, "// new password", class: "mb-2" %>
      <%= form.password_field :password,
        required: true, autocomplete: "new-password", maxlength: 72 %>
    </div>
    <div>
      <%= form.label :password_confirmation, "// confirm new password", class: "mb-2" %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72 %>
    </div>

    <div class="pt-4">
      <%= form.submit "save", class: "ui-button ui-button--accent" %>
    </div>
  <% end %>
<% end %>
