{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(*)",
      "Search(*)",
      "Edit(*)",
      "Write(*)",
      "Bash(bin/rails *)",
      "Bash(bundle exec rails *)",
      "Bash(bundle exec rubocop *)",
      "Read(//Users/bolt/code/skills/skills/the-rails-way/**)",
      "Bash(git mv *)",
      "Bash(grep *)",
      "Bash(xargs ls -la)"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(git push *)",
      "Bash(docker run *)",
      "Bash(docker exec *)",
      "Bash(kubectl *)",
      "Bash(terraform apply *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(secrets/**)",
      "Read(config/master.key)",
      "Read(config/credentials*.yml.enc)",
      "Read(~/.ssh/**)"
    ],
    "defaultMode": "acceptEdits"
  }
}
