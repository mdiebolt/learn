{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read(*)",
      "Search(*)",
      "Edit(*)",
      "Write(*)",
      "Bash(bundle exec rails test *)",
      "Bash(bin/rails test *)",
      "Bash(bin/rails db:prepare)",
      "Bash(bin/rails db:migrate)",
      "Bash(bin/rails db:rollback)",
      "Bash(bin/rails assets:precompile)",
      "Bash(bundle exec rubocop *)"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(git push *)",
      "Bash(docker run *)",
      "Bash(docker exec *)",
      "Bash(kubectl *)",
      "Bash(terraform apply *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(secrets/**)",
      "Read(config/master.key)",
      "Read(config/credentials*.yml.enc)",
      "Read(~/.ssh/**)"
    ]
  }
}
